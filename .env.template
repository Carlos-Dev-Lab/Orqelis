# Server Configuration
NODE_ENV="development"
PORT="3001"
FRONTEND_ORIGIN="http://localhost:3000"

# Database Configuration
# For SQLite: file:./dev.db (local) o file:/app/data/dev.db (docker)
DATABASE_URL="file:./dev.db"
DB_PROVIDER="sqlite"

# Authentication Secrets
# [REQUERIDO EN PRODUCCIÓN] Generar con: pnpm gen:secrets o openssl rand -hex 32
JWT_SECRET=""
REFRESH_TOKEN_SECRET=""
# Clave para encriptar credenciales de conexiones SSH/DB (mínimo 32 caracteres)
CREDENTIAL_ENCRYPTION_KEY=""

# Setup Security
# [REQUERIDO EN PRODUCCIÓN] Token de seguridad para completar el Wizard inicial
SETUP_TOKEN=""

# Auth Features
ALLOW_PUBLIC_REGISTRATION="false"
ALLOW_DB_RECONFIGURATION="false"

# Google Auth (Opcional)
GOOGLE_CLIENT_ID=""
ALLOWED_GOOGLE_DOMAINS=""

# Frontend Configuration
VITE_API_BASE_URL="/api"
